# =============================================================================
# India Story Project — Flutter Environment Variables
# =============================================================================
# Flutter uses --dart-define to inject environment variables at build time.
#
# Usage:
#   flutter run --dart-define-from-file=.env
#   flutter build apk --dart-define-from-file=.env
#   flutter build appbundle --dart-define-from-file=.env
#
# Or use individual --dart-define flags:
#   flutter run --dart-define=API_BASE_URL=https://isp-backend-09fw.onrender.com
# =============================================================================

# --- Backend API ---
# Production: https://isp-backend-09fw.onrender.com
# Local (Android emulator): http://10.0.2.2:3000
# Local (iOS simulator): http://localhost:3000
# Local (physical device): http://<your-ip>:3000
API_BASE_URL=https://isp-backend-09fw.onrender.com
