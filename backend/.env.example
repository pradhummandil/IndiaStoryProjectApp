# =============================================================================
# India Story Project — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control!
# =============================================================================

# --- Server ---
NODE_ENV=development
PORT=3000

# --- Database (PostgreSQL via Prisma) ---
# Obtain from Supabase / your PostgreSQL provider
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public
DIRECT_URL=postgresql://user:password@host:5432/dbname?schema=public

# --- CORS ---
# Comma-separated origins or * for all
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# --- JWT ---
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=your-jwt-secret-here

# --- MongoDB (optional) ---
# Only needed if you use MongoDB-specific features
MONGO_ENABLED=false
MONGODB_URI=
MONGODB_DB_NAME=

# --- Cloudinary (optional) ---
CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Firebase Admin (optional) ---
# Encode your Firebase service account JSON as base64:
#   Get serviceAccountKey.json from Firebase Console
#   certutil -encode serviceAccountKey.json encoded.txt (Windows)
#   cat serviceAccountKey.json | base64 (Linux/Mac)
FIREBASE_ENABLED=false
FIREBASE_SERVICE_ACCOUNT_JSON=base64-encoded-service-account-json
FIREBASE_PROJECT_ID=your-firebase-project-id

# --- Morgan (HTTP logging) ---
MORGAN_FORMAT=combined

# --- Body size limits ---
JSON_BODY_LIMIT=1mb
URL_ENCODED_LIMIT=1mb

# --- Trust proxy (set true behind nginx/Render) ---
TRUST_PROXY=true

# --- Socket.IO ---
SOCKET_IO_CORS_ORIGIN=*
